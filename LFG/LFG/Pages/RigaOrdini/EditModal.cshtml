@page
@using Microsoft.AspNetCore.Mvc.Localization
@using LFG.Localization
@using LFG.Web.Pages.RigaOrdini
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using LFG.RigaOrdini; 
@using System.Globalization
@inject IHtmlLocalizer<LFGResource> L
@model EditModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/RigaOrdini/EditModal" autocomplete="off">
    <abp-modal id="RigaOrdineEditModal">
        <abp-modal-header title="@L["Update"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="Id" />
                    <abp-input asp-for="RigaOrdine.ConcurrencyStamp" hidden="true" suppress-label="true"/>
            <abp-input asp-for="RigaOrdine.Quantita"    />
            <abp-input asp-for="RigaOrdine.PrezzoUnitario"   data-val="false" />
                                <abp-select asp-for="RigaOrdine.OrdineId" asp-items="Model.OrdineLookupList" label="@L["Ordine"].Value"/>
            <abp-select asp-for="RigaOrdine.VarianteProdottoId" asp-items="Model.VarianteProdottoLookupList" label="@L["VarianteProdotto"].Value"/>
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>