@page "{id:guid}"
@model LFG.Pages.Vetrina.Prodotto.IndexModel
@using LFG.Pages.Vetrina.Prodotto
@using LFG.Recensioni
@{
    Layout = null;
    var isLfg = string.Equals(Model.Sezione, "LFG", System.StringComparison.OrdinalIgnoreCase);
    var sezioneProdotto = Model.Sezione?.ToUpperInvariant() ?? "LFG";
    ViewBag.Title = Model.Nome;
    var imgPrincipale = Model.Varianti.Any() ? Model.Varianti.First().Immagini.First() : "/images/placeholder.png";
    var miniatureIniziali = Model.Varianti.Any() ? Model.Varianti.First().Immagini : new List<string>();
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/vetrina.css" asp-append-version="true" />
    <style>
        /* ── Galleria immagini variante ──────────────────── */
        .v-thumbs {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            margin-top: .75rem;
        }
        .v-thumb {
            width: 64px;
            height: 64px;
            object-fit: cover;
            cursor: pointer;
            opacity: .6;
            border: 2px solid transparent;
            transition: opacity .15s, border-color .15s;
        }
        .v-thumb:hover { opacity: .9; }
        .v-thumb.is-active {
            opacity: 1;
            border-color: #c8a96e;
        }
        .v-variant.is-selected {
            border-color: #c8a96e;
            font-weight: 700;
        }

        /* ── Gating popup ────────────────────────────────── */
        .v-popup-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .55);
            z-index: 900;
            align-items: center;
            justify-content: center;
        }
        .v-popup-overlay.is-open { display: flex; }
        .v-popup {
            background: #fff;
            max-width: 420px;
            width: calc(100% - 2rem);
            padding: 2.5rem 2rem 2rem;
            position: relative;
        }
        .shop--lfg .v-popup { background: #111; color: #f5f5f5; }
        .v-popup__close {
            position: absolute; top: 1rem; right: 1rem;
            background: none; border: none; cursor: pointer;
            font-size: 1.2rem; line-height: 1; color: inherit; opacity: .55;
        }
        .v-popup__close:hover { opacity: 1; }
        .v-popup__eyebrow {
            font-family: 'Space Mono', monospace; font-size: .65rem;
            letter-spacing: .12em; opacity: .5; text-transform: uppercase; margin-bottom: .75rem;
        }
        .v-popup__title {
            font-family: 'Barlow', sans-serif; font-size: 1.3rem; font-weight: 800;
            text-transform: uppercase; margin: 0 0 .75rem;
        }
        .v-popup__body { font-size: .9rem; line-height: 1.6; opacity: .8; margin-bottom: 1.5rem; }
        .v-popup__actions { display: flex; flex-wrap: wrap; gap: .6rem; }

        /* ── Recensioni ──────────────────────────────────── */
        .v-reviews {
            padding: 4rem 0;
            border-top: 1px solid rgba(128,128,128,.15);
        }
        .v-reviews__header {
            display: flex;
            align-items: baseline;
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .v-reviews__title {
            font-family: 'Barlow', sans-serif;
            font-size: 1.4rem;
            font-weight: 800;
            text-transform: uppercase;
            margin: 0;
        }
        .v-reviews__count {
            font-family: 'Space Mono', monospace;
            font-size: .7rem;
            letter-spacing: .08em;
            opacity: .45;
            text-transform: uppercase;
        }
        /* Form */
        .v-review-form {
            border: 1px solid rgba(128,128,128,.2);
            padding: 1.75rem 1.5rem;
            margin-bottom: 2.5rem;
        }
        .v-review-form__title {
            font-family: 'Space Mono', monospace;
            font-size: .7rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            opacity: .5;
            margin: 0 0 1.25rem;
        }
        .v-review-form__stars {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-end;
            gap: .25rem;
            margin-bottom: 1.25rem;
        }
        .v-review-form__stars input[type="radio"] { display: none; }
        .v-review-form__stars label {
            font-size: 1.6rem;
            cursor: pointer;
            color: rgba(128,128,128,.3);
            transition: color .15s;
        }
        .v-review-form__stars input:checked ~ label,
        .v-review-form__stars label:hover,
        .v-review-form__stars label:hover ~ label {
            color: #c8a96e;
        }
        .v-review-form textarea {
            width: 100%;
            min-height: 90px;
            padding: .75rem;
            border: 1px solid rgba(128,128,128,.25);
            background: transparent;
            color: inherit;
            font-family: inherit;
            font-size: .9rem;
            resize: vertical;
            box-sizing: border-box;
            margin-bottom: 1rem;
        }
        .v-review-form textarea:focus { outline: none; border-color: currentColor; }
        /* Cards recensione */
        .v-review-list { display: flex; flex-direction: column; gap: 1.25rem; }
        .v-review {
            padding: 1.25rem 1.5rem;
            border-left: 3px solid rgba(128,128,128,.15);
        }
        .v-review.is-mine {
            border-left-color: #c8a96e;
            background: rgba(200,169,110,.04);
        }
        .v-review__meta {
            display: flex;
            align-items: center;
            gap: .75rem;
            margin-bottom: .5rem;
        }
        .v-review__stars { color: #c8a96e; letter-spacing: .05em; }
        .v-review__stars-empty { color: rgba(128,128,128,.3); }
        .v-review__date {
            font-family: 'Space Mono', monospace;
            font-size: .65rem;
            letter-spacing: .06em;
            opacity: .4;
        }
        .v-review__mine-tag {
            font-family: 'Space Mono', monospace;
            font-size: .6rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #c8a96e;
        }
        .v-review__commento { font-size: .9rem; line-height: 1.65; opacity: .85; margin: 0; }
        .v-review-empty {
            font-family: 'Space Mono', monospace;
            font-size: .75rem;
            letter-spacing: .06em;
            opacity: .35;
            text-transform: uppercase;
        }
        /* Azioni prodotto */
        .v-actions {
            display: flex;
            flex-wrap: wrap;
            gap: .6rem;
            margin-top: 1rem;
        }
        /* Recensione già inviata */
        .v-review-done {
            padding: 1rem 1.5rem;
            border: 1px solid rgba(200,169,110,.3);
            margin-bottom: 2.5rem;
            font-size: .85rem;
            opacity: .75;
        }
    </style>
</head>

<body class="vetrina @(isLfg ? "shop--lfg" : "shop--glf")">

    <partial name="../Account/_VetrinaNavbar" />

    @if (!string.IsNullOrEmpty(Model.MessaggioConferma))
    {
        <div class="v-msg v-msg--ok" role="status" data-autohide="4500">
            <span class="v-msg__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M8.5 12.5l2.5 2.5 5-5" />
                </svg>
            </span>
            <span>@Model.MessaggioConferma</span>
            <button type="button" class="v-msg__close" aria-label="Chiudi">&times;</button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.MessaggioErrore))
    {
        <div class="v-msg v-msg--error" role="alert" data-autohide="6000">
            <span class="v-msg__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9" />
                    <line x1="12" y1="8" x2="12" y2="13" />
                    <line x1="12" y1="16.5" x2="12" y2="16.51" />
                </svg>
            </span>
            <span>@Model.MessaggioErrore</span>
            <button type="button" class="v-msg__close" aria-label="Chiudi">&times;</button>
        </div>
    }

    <section class="v-detail">
        <div class="v-container v-detail__inner">

            <div class="v-detail__media">
                <img id="mainImage" src="@imgPrincipale" alt="@Model.Nome" />
                <div id="thumbStrip" class="v-thumbs">
                    @if (miniatureIniziali.Count > 1)
                    {
                        @foreach (var url in miniatureIniziali)
                        {
                            <img class="v-thumb @(url == imgPrincipale ? "is-active" : "")" src="@url" data-img="@url" alt="miniatura" />
                        }
                    }
                </div>
            </div>

            <div class="v-detail__info">
                <h1 class="v-detail__name">@Model.Nome</h1>
                <p class="v-detail__price">€ @Model.Prezzo</p>

                @if (!string.IsNullOrEmpty(Model.Descrizione))
                {
                    <p class="v-detail__desc">@Model.Descrizione</p>
                }

                @if (Model.Varianti.Any())
                {
                    <div class="v-variants">
                        <span class="v-variants__label">Varianti</span>
                        <div class="v-variants__list">
                            @foreach (var v in Model.Varianti)
                            {
                                var disponibile = v.QtaMagazzino > 0;
                                var selezionata = v.Id == Model.Varianti.First().Id;
                                <button type="button"
                                        class="v-variant @(disponibile ? "" : "is-out") @(selezionata ? "is-selected" : "")"
                                        data-variante-id="@v.Id"
                                        data-immagini="@string.Join("|", v.Immagini)"
                                        disabled="@(!disponibile)">
                                    @v.Taglia · @v.Colore
                                    @if (!disponibile)
                                    {
                                        <span class="v-variant__out">esaurito</span>
                                    }
                                </button>
                            }
                        </div>
                    </div>

                    <div class="v-actions">
                        @if (Model.PuoAgire)
                        {
                            <form method="post" asp-page-handler="CarrelloAggiungi">
                                @Html.AntiForgeryToken()
                                <input type="hidden" id="varianteIdInput" name="VarianteId" value="@Model.Varianti.First().Id" />
                                <button type="submit" class="v-btn v-btn--primary">
                                    AGGIUNGI AL CARRELLO
                                </button>
                            </form>
                            <form method="post" asp-page-handler="WishlistToggle">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="v-btn v-btn--outline"
                                        title="@(Model.InWishlist ? "Rimuovi dai preferiti" : "Aggiungi ai preferiti")">
                                    <svg width="18" height="18" viewBox="0 0 24 24"
                                         fill="@(Model.InWishlist ? "currentColor" : "none")"
                                         stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z" />
                                    </svg>
                                </button>
                            </form>
                        }
                        else
                        {
                            <button type="button" class="v-btn v-btn--outline"
                                    title="Aggiungi ai preferiti"
                                    onclick="document.getElementById('gatingPopup').classList.add('is-open')">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z" />
                                </svg>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <p class="v-empty">Nessuna variante disponibile.</p>
                }
            </div>

        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════
         RECENSIONI
         ══════════════════════════════════════════════════════════ -->
    <section class="v-reviews">
        <div class="v-container">

            <div class="v-reviews__header">
                <h2 class="v-reviews__title">Recensioni</h2>
                <span class="v-reviews__count">@Model.Recensioni.Count @(Model.Recensioni.Count == 1 ? "RECENSIONE" : "RECENSIONI")</span>
            </div>

            @if (Model.Stato == IndexModel.StatoRecensione.PuoRecensire)
            {
                <!-- Form inserimento -->
                <form method="post" asp-page-handler="Recensione" class="v-review-form">
                    @Html.AntiForgeryToken()
                    <p class="v-review-form__title">Lascia la tua recensione</p>

                    <div class="v-review-form__stars" role="radiogroup" aria-label="Valutazione">
                        @for (int s = RecensioneConsts.ValutazioneMaxLength; s >= RecensioneConsts.ValutazioneMinLength; s--)
                        {
                            var sid = $"star{s}";
                            <input type="radio" id="@sid" name="Valutazione" value="@s"
                                   @(Model.Valutazione == s ? "checked" : "") />
                            <label for="@sid" title="@s stelle">&#9733;</label>
                        }
                    </div>

                    <textarea name="Commento" placeholder="Scrivi un commento (facoltativo)"
                              maxlength="@RecensioneConsts.CommentoMaxLength">@Model.Commento</textarea>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="v-msg v-msg--error" style="margin-top:-.5rem">
                            <span asp-validation-for="Valutazione"></span>
                            <span asp-validation-for="Commento"></span>
                        </div>
                    }

                    <button type="submit" class="v-btn @(isLfg ? "v-btn--primary" : "v-btn--dark")">
                        PUBBLICA RECENSIONE
                    </button>
                </form>
            }
            else if (Model.Stato == IndexModel.StatoRecensione.HaGiaRecensito)
            {
                <div class="v-review-done">
                    Hai già inviato una recensione per questo prodotto. Scorrere in basso per visualizzarla.
                </div>
            }

            <!-- Lista recensioni -->
            @if (Model.Recensioni.Any())
            {
                <div class="v-review-list">
                    @foreach (var r in Model.Recensioni)
                    {
                        <div class="v-review @(r.IsMia ? "is-mine" : "")">
                            <div class="v-review__meta">
                                <span class="v-review__stars" aria-label="@r.Valutazione stelle su 5">
                                    @for (int i = 1; i <= RecensioneConsts.ValutazioneMaxLength; i++)
                                    {
                                        if (i <= r.Valutazione)
                                        {
                                            <span>&#9733;</span>
                                        }
                                        else
                                        {
                                            <span class="v-review__stars-empty">&#9733;</span>
                                        }
                                    }
                                </span>
                                <span class="v-review__date">@r.DataRecensione.ToString("dd MMM yyyy")</span>
                                @if (r.IsMia)
                                {
                                    <span class="v-review__mine-tag">La tua recensione</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(r.Commento))
                            {
                                <p class="v-review__commento">@r.Commento</p>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="v-review-empty">Ancora nessuna recensione — sii il primo.</p>
            }

        </div>
    </section>

    @if (!Model.PuoAgire)
    {
        <!-- Popup gating cross-sezione -->
        <div id="gatingPopup" class="v-popup-overlay" role="dialog" aria-modal="true"
             onclick="if(event.target===this)this.classList.remove('is-open')">
            <div class="v-popup">
                <button class="v-popup__close"
                        onclick="document.getElementById('gatingPopup').classList.remove('is-open')"
                        aria-label="Chiudi">&times;</button>

                @if (Model.SezioneUtente != null)
                {
                    <p class="v-popup__eyebrow">Accesso riservato</p>
                    <h2 class="v-popup__title">Collezione @sezioneProdotto</h2>
                    <p class="v-popup__body">
                        Questa collezione è riservata ai membri <strong>@sezioneProdotto</strong>.<br />
                        Il tuo account è registrato nella sezione <strong>@Model.SezioneUtente</strong>.
                    </p>
                    <div class="v-popup__actions">
                        <a href="/Vetrina/Account/Register?sezione=@sezioneProdotto"
                           class="v-btn @(isLfg ? "v-btn--dark" : "v-btn--primary")">
                            REGISTRATI PER @sezioneProdotto &rarr;
                        </a>
                        <button type="button" class="v-btn v-btn--outline"
                                onclick="document.getElementById('gatingPopup').classList.remove('is-open')">
                            CHIUDI
                        </button>
                    </div>
                }
                else
                {
                    <p class="v-popup__eyebrow">Accesso richiesto</p>
                    <h2 class="v-popup__title">Accedi per acquistare</h2>
                    <p class="v-popup__body">
                        Accedi o crea un account <strong>@sezioneProdotto</strong> per aggiungere
                        prodotti al carrello.
                    </p>
                    <div class="v-popup__actions">
                        <a href="/Vetrina/Account/Login" class="v-btn v-btn--dark">ACCEDI &rarr;</a>
                        <a href="/Vetrina/Account/Register?sezione=@sezioneProdotto"
                           class="v-btn v-btn--outline">REGISTRATI</a>
                    </div>
                }
            </div>
        </div>
    }

    <script>
        function mostraImmagine(url) {
            document.getElementById('mainImage').src = url;
            document.querySelectorAll('#thumbStrip .v-thumb').forEach(function (thumb) {
                thumb.classList.toggle('is-active', thumb.getAttribute('data-img') === url);
            });
        }

        function rendiThumbStrip(urls) {
            var strip = document.getElementById('thumbStrip');
            strip.innerHTML = '';
            if (urls.length < 2) return;
            urls.forEach(function (url, indice) {
                var img = document.createElement('img');
                img.className = 'v-thumb' + (indice === 0 ? ' is-active' : '');
                img.src = url;
                img.setAttribute('data-img', url);
                img.alt = 'miniatura';
                img.addEventListener('click', function () {
                    mostraImmagine(url);
                });
                strip.appendChild(img);
            });
        }

        document.querySelectorAll('.v-variant[data-immagini]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var urls = btn.getAttribute('data-immagini').split('|').filter(Boolean);
                if (urls.length) {
                    mostraImmagine(urls[0]);
                    rendiThumbStrip(urls);
                }

                document.querySelectorAll('.v-variant').forEach(function (altro) {
                    altro.classList.toggle('is-selected', altro === btn);
                });
                var varianteIdInput = document.getElementById('varianteIdInput');
                if (varianteIdInput) varianteIdInput.value = btn.getAttribute('data-variante-id');
            });
        });

        document.querySelectorAll('#thumbStrip .v-thumb').forEach(function (thumb) {
            thumb.addEventListener('click', function () {
                mostraImmagine(thumb.getAttribute('data-img'));
            });
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                var popup = document.getElementById('gatingPopup');
                if (popup) popup.classList.remove('is-open');
            }
        });

        document.querySelectorAll('.v-msg').forEach(function (msg) {
            var nascondi = function () {
                msg.classList.add('is-leaving');
                setTimeout(function () { msg.style.display = 'none'; }, 250);
            };

            var closeBtn = msg.querySelector('.v-msg__close');
            if (closeBtn) closeBtn.addEventListener('click', nascondi);

            var autohide = parseInt(msg.getAttribute('data-autohide'), 10);
            if (autohide) setTimeout(nascondi, autohide);
        });

        @if (Model.CarrelloAggiornato)
        {
            <text>
            var cartLink = document.getElementById('cartIconBtn');
            if (cartLink) {
                cartLink.classList.add('is-bumping');
                setTimeout(function () { cartLink.classList.remove('is-bumping'); }, 400);
            }
            </text>
        }
    </script>

</body>
</html>
