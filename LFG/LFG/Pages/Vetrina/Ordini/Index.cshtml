@page
@model LFG.Pages.Vetrina.Ordini.IndexModel
@using LFG.Helpers
@{
    Layout = null;
    ViewBag.Title = "I miei ordini";
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/vetrina.css" asp-append-version="true" />
    <style>
        .v-orders {
            padding-top: calc(var(--header-h) + 48px);
            padding-bottom: 80px;
            min-height: 100svh;
        }
        .v-orders-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .v-order {
            border: 1px solid rgba(128,128,128,.15);
        }
        .v-order__summary {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            width: 100%;
            padding: 1rem 1.25rem;
            background: none;
            border: none;
            cursor: pointer;
            text-align: left;
            font-family: inherit;
            color: inherit;
            flex-wrap: wrap;
        }
        .v-order__summary-field {
            display: flex;
            flex-direction: column;
            gap: .2rem;
        }
        .v-order__summary-label {
            font-family: 'Space Mono', monospace;
            font-size: .62rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            opacity: .5;
        }
        .v-order__summary-value {
            font-size: .85rem;
            font-weight: 700;
        }
        .v-order__summary-spacer { flex: 1 1 auto; }
        .v-order__chevron {
            transition: transform .2s;
            flex-shrink: 0;
        }
        .v-order.is-expanded .v-order__chevron {
            transform: rotate(180deg);
        }
        .v-order__detail {
            display: none;
            padding: 0 1.25rem 1.25rem;
            border-top: 1px solid rgba(128,128,128,.15);
        }
        .v-order.is-expanded .v-order__detail {
            display: block;
        }
        .v-order__meta {
            display: flex;
            flex-direction: column;
            gap: .35rem;
            font-size: .85rem;
            opacity: .85;
            margin: 1rem 0 1.25rem;
        }
        .v-order-row {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(128,128,128,.1);
            margin-bottom: 1rem;
        }
        .v-order-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        .v-order-row__img {
            width: 64px;
            height: 64px;
            object-fit: cover;
            flex-shrink: 0;
        }
        .v-order-row__info { flex: 1 1 auto; min-width: 0; }
        .v-order-row__name { font-weight: 700; margin: 0 0 .2rem; }
        .v-order-row__variant {
            font-family: 'Space Mono', monospace;
            font-size: .68rem;
            letter-spacing: .05em;
            text-transform: uppercase;
            opacity: .5;
        }
        .v-order-row__price {
            font-family: 'Space Mono', monospace;
            font-size: .75rem;
            opacity: .65;
            margin: .2rem 0 0;
        }
        .v-order-row__qty {
            font-family: 'Space Mono', monospace;
            font-size: .78rem;
            opacity: .7;
            min-width: 40px;
            text-align: center;
        }
        .v-order-row__subtotale {
            font-weight: 700;
            min-width: 80px;
            text-align: right;
        }
    </style>
</head>
<body class="vetrina">

    <partial name="../Account/_VetrinaNavbar" />

    <section class="v-orders">
        <div class="v-container">
            <h1 class="v-section-title">I miei ordini</h1>

            @if (!Model.Autenticato)
            {
                <p class="v-empty">
                    Devi <a href="/Vetrina/Account/Login">accedere</a> per vedere i tuoi ordini.
                </p>
            }
            else if (!Model.Ordini.Any())
            {
                <p class="v-empty">Non hai ancora effettuato nessun ordine.</p>
            }
            else
            {
                <div class="v-orders-list">
                    @foreach (var o in Model.Ordini)
                    {
                        <div class="v-order">
                            <button type="button" class="v-order__summary" data-order-toggle>
                                <div class="v-order__summary-field">
                                    <span class="v-order__summary-label">Data</span>
                                    <span class="v-order__summary-value">@o.DataOrdine.ToString("dd MMM yyyy")</span>
                                </div>
                                <div class="v-order__summary-field">
                                    <span class="v-order__summary-label">Pezzi</span>
                                    <span class="v-order__summary-value">@o.TotalePezzi</span>
                                </div>
                                <div class="v-order__summary-field">
                                    <span class="v-order__summary-label">Pagamento</span>
                                    <span class="v-order__summary-value">@o.MetodoPagamento</span>
                                </div>
                                <div class="v-order__summary-field">
                                    <span class="v-order__summary-label">Stato</span>
                                    <span class="v-order__summary-value">@o.Stato</span>
                                </div>
                                <span class="v-order__summary-spacer"></span>
                                <div class="v-order__summary-field">
                                    <span class="v-order__summary-label">Totale</span>
                                    <span class="v-order__summary-value">&euro; @PrezzoHelper.ToCanonico(o.ImportoTotale)</span>
                                </div>
                                <svg class="v-order__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </button>

                            <div class="v-order__detail">
                                <div class="v-order__meta">
                                    <span>Spedizione a: @o.IndirizzoTesto</span>
                                    @if (!string.IsNullOrEmpty(o.ScontoCodice))
                                    {
                                        <span>Sconto applicato: @o.ScontoCodice</span>
                                    }
                                </div>

                                @foreach (var r in o.Righe)
                                {
                                    <div class="v-order-row">
                                        <img class="v-order-row__img" src="@r.UrlImmagine" alt="@r.Nome" />
                                        <div class="v-order-row__info">
                                            <p class="v-order-row__name">@r.Nome</p>
                                            <span class="v-order-row__variant">@r.Taglia · @r.Colore</span>
                                            <p class="v-order-row__price">€ @PrezzoHelper.ToCanonico(r.PrezzoUnitario) / cad.</p>
                                        </div>
                                        <span class="v-order-row__qty">&times; @r.Quantita</span>
                                        <span class="v-order-row__subtotale">€ @PrezzoHelper.ToCanonico(r.Subtotale)</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <script>
        document.querySelectorAll('[data-order-toggle]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                btn.closest('.v-order').classList.toggle('is-expanded');
            });
        });
    </script>

</body>
</html>
