@using LFG.Ordini
@using LFG.RigaOrdini
@inject LFG.Clienti.IClientiAppService ClientiSvc
@inject Volo.Abp.Domain.Repositories.IRepository<Ordine, System.Guid> OrdineRepo
@inject Volo.Abp.Domain.Repositories.IRepository<RigaOrdine, System.Guid> RigaOrdineRepo
@{
    string? sezioneUtente = null;
    int pezziCarrello = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        var clienteCorrente = await ClientiSvc.GetClienteCorrenteAsync();
        sezioneUtente = clienteCorrente?.Sezione;

        if (clienteCorrente != null)
        {
            var bozze = await OrdineRepo.GetListAsync(o => o.ClienteId == clienteCorrente.Id && o.Stato == "Bozza");
            var ordineBozza = bozze.FirstOrDefault();
            if (ordineBozza != null)
            {
                var righeBozza = await RigaOrdineRepo.GetListAsync(r => r.OrdineId == ordineBozza.Id);
                foreach (var riga in righeBozza)
                {
                    pezziCarrello += riga.Quantita;
                }
            }
        }
    }
    var isLfgUtente = string.Equals(sezioneUtente, "LFG", StringComparison.OrdinalIgnoreCase);
}
<header class="v-header">
    <div class="v-container v-header__inner">
        <a class="v-logo" href="/Vetrina">
            <span class="v-logo__name">LFG | GLF</span>
            <span class="v-logo__tagline">Life is Good &middot; Good Life is Better</span>
        </a>
        <nav class="v-nav">
            <a href="#">STUDIO</a>
            <a href="#">COLLEZIONI</a>
            <a href="/Vetrina/Shop?sezione=LFG">LFG</a>
            <a href="/Vetrina/Shop?sezione=GLF">GLF</a>
            <a href="#">CONTATTI</a>
        </nav>
        <div class="v-header__actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (sezioneUtente != null)
                {
                    <span class="v-header__badge v-header__badge--@(isLfgUtente ? "lfg" : "glf")">
                        @sezioneUtente
                    </span>
                }
                <a href="/Vetrina/Preferiti" class="v-icon-btn" aria-label="Preferiti" title="Preferiti">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z" />
                    </svg>
                </a>
                <a href="/Vetrina/Carrello" class="v-icon-btn v-cart-link" id="cartIconBtn" aria-label="Carrello" title="Carrello">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 7h12l1 13H5L6 7z" />
                        <path d="M9 7a3 3 0 1 1 6 0" />
                    </svg>
                    <span class="v-cart-badge @(pezziCarrello > 0 ? "" : "is-hidden")" id="cartBadge">@pezziCarrello</span>
                </a>
                <a href="/Vetrina/Account" class="v-header__user">@User.Identity.Name</a>
                <a href="/Vetrina/Account/Logout" class="v-btn v-btn--outline">ESCI &rarr;</a>
            }
            else
            {
                <a href="/Vetrina/Account/Login" class="v-icon-btn" aria-label="Accedi">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </a>
                <a href="/Vetrina/Account/Login" class="v-btn v-btn--dark">ACCEDI &rarr;</a>
                <a href="/Vetrina/Account/Register" class="v-btn v-btn--outline">REGISTRATI</a>
            }
        </div>
    </div>
</header>
