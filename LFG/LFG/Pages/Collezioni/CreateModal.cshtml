@page
@using Microsoft.AspNetCore.Mvc.Localization
@using LFG.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using LFG.Web.Pages.Collezioni
 @using LFG.Collezioni; 
@using System.Globalization
@inject IHtmlLocalizer<LFGResource> L
@model CreateModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/Collezioni/CreateModal" autocomplete="off">
    <abp-modal id="CollezioneCreateModal">
        <abp-modal-header title="@L["NewCollezione"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="Collezione.Nome"    />
            <abp-input asp-for="Collezione.Stagione"    />
            <abp-date-picker auto-update-input="true" today-button-classes="btn-primary" asp-for="Collezione.Anno" data-date="@DateTime.Now.ToString("yyyy-MM-dd")" />
            <abp-input asp-for="Collezione.Sezione"    />
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>