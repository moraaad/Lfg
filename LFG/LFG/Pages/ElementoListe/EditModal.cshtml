@page
@using Microsoft.AspNetCore.Mvc.Localization
@using LFG.Localization
@using LFG.Web.Pages.ElementoListe
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using LFG.ElementoListe; 
@using System.Globalization
@inject IHtmlLocalizer<LFGResource> L
@model EditModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/ElementoListe/EditModal" autocomplete="off">
    <abp-modal id="ElementoListaEditModal">
        <abp-modal-header title="@L["Update"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="Id" />
                    <abp-input asp-for="ElementoLista.ConcurrencyStamp" hidden="true" suppress-label="true"/>
            <abp-date-picker auto-update-input="true" today-button-classes="btn-primary" asp-for="ElementoLista.DataAggiunta"  />
                                <abp-select asp-for="ElementoLista.VarianteProdottoId" asp-items="Model.VarianteProdottoLookupListRequired" label="@L["VarianteProdotto"].Value"/>
            <abp-select asp-for="ElementoLista.ListaDesideriId" asp-items="Model.ListaDesideriLookupList" label="@L["ListaDesideri"].Value"/>
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>